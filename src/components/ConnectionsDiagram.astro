---
import { DEPARTMENT_COLOR } from "../content/config";

export interface RelatedTopic {
  slug: string;
  title: string;
  note?: string;
  position: "before" | "after" | "parallel";
  department?: string;
}

interface Props {
  currentTitle: string;
  currentDepartment?: string;
  related: RelatedTopic[];
}

const { currentTitle, currentDepartment, related } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

const before = related.filter((r) => r.position === "before");
const after = related.filter((r) => r.position === "after");
const parallel = related.filter((r) => r.position === "parallel");

const hasBefore = before.length > 0;
const hasAfter = after.length > 0;
const hasParallel = parallel.length > 0;
const hasConnections = related.length > 0;

function colorFor(dept?: string): string {
  if (!dept) return "var(--text-muted)";
  return (
    (DEPARTMENT_COLOR as Record<string, string>)[dept] ?? "var(--text-muted)"
  );
}
---

{
  hasConnections ? (
    <div class="connections-graph">
      <div class="timeline-row">
        {hasBefore && (
          <>
            <div class="side-col">
              <div class="col-label" aria-hidden="true">
                ← Comes before
              </div>
              <div class="col-items">
                {before.map((b) => (
                  <a
                    href={`${baseUrl}/topics/${b.slug}/`}
                    class="related-card"
                    style={`--dept-color: ${colorFor(b.department)}`}
                  >
                    {b.title}
                  </a>
                ))}
              </div>
            </div>
            <div class="connector" aria-hidden="true" />
          </>
        )}

        <div class="current-col">
          <div
            class="current-card"
            style={`--dept-color: ${colorFor(currentDepartment)}`}
          >
            {currentTitle}
          </div>
        </div>

        {hasAfter && (
          <>
            <div class="connector" aria-hidden="true" />
            <div class="side-col">
              <div class="col-label" aria-hidden="true">
                Comes after →
              </div>
              <div class="col-items">
                {after.map((a) => (
                  <a
                    href={`${baseUrl}/topics/${a.slug}/`}
                    class="related-card"
                    style={`--dept-color: ${colorFor(a.department)}`}
                  >
                    {a.title}
                  </a>
                ))}
              </div>
            </div>
          </>
        )}
      </div>

      {hasParallel && (
        <>
          <hr class="parallel-separator" aria-hidden="true" />
          <div class="parallel-label" aria-hidden="true">
            In parallel
          </div>
          <div class="parallel-row">
            {parallel.map((p) => (
              <a
                href={`${baseUrl}/topics/${p.slug}/`}
                class="related-card"
                style={`--dept-color: ${colorFor(p.department)}`}
              >
                {p.title}
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  ) : (
    <p class="no-connections">No related topics recorded yet.</p>
  )
}

<style>
  .connections-graph {
    --card-w: 220px;

    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 1.5rem 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
  }

  .parallel-label,
  .col-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.45rem;
  }

  .parallel-separator {
    border: none;
    border-top: 1px dashed var(--border);
    width: 80%;
    max-width: 600px;
    margin: 1.4rem 0 0.9rem;
  }

  .parallel-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    max-width: 100%;
  }

  .timeline-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    flex-wrap: nowrap;
  }

  .side-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    flex: 0 0 auto;
  }

  .col-items {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: stretch;
  }

  .current-col {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .connector {
    width: 28px;
    height: 2px;
    background: var(--border);
    border-radius: 1px;
    flex: 0 0 28px;
  }

  .related-card,
  .current-card {
    box-sizing: border-box;
    width: var(--card-w);
    min-height: 64px;
    padding: 0.6rem 0.9rem;
    border-radius: 6px;
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.35;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease;
  }

  .related-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-left: 4px solid var(--dept-color, var(--text-muted));
    font-weight: 500;
  }

  .related-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.18);
    text-decoration: none;
  }

  .current-card {
    background: color-mix(
      in srgb,
      var(--dept-color, #5b8def) 18%,
      var(--bg-elevated)
    );
    border: 2px solid var(--dept-color, #5b8def);
    font-weight: 700;
  }

  .no-connections {
    color: var(--text-muted);
    font-style: italic;
  }

  @media (max-width: 720px) {
    .connections-graph {
      --card-w: 180px;
    }
    .timeline-row {
      flex-wrap: wrap;
      flex-direction: column;
      align-items: center;
    }
    .connector {
      width: 2px;
      height: 22px;
      flex: 0 0 22px;
    }
  }
</style>
