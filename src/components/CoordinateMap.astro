---
import { getCollection } from "astro:content";
import {
  ML_TYPES,
  DEPARTMENTS,
  DEPARTMENT_CATEGORIES,
  DEPARTMENT_TO_CATEGORY,
} from "../content/config";

const topics = await getCollection("topics");
const topicsData = topics.map((t) => ({
  slug: t.slug,
  title: t.data.title,
  maturity: t.data.maturity,
  ml_types: t.data.ml_types,
  departments: t.data.departments,
  connections: t.data.connections.map((c) => ({
    to: c.to.slug,
    relation: c.relation,
  })),
}));

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

const CATEGORY_COLOR: Record<string, string> = {
  "Technical Security": "#5b8def",
  "Process & System Security": "#5fae5f",
  "Organizational Security": "#f1a983",
};

const CATEGORY_TINT: Record<string, string> = {
  "Technical Security": "rgba(91, 141, 239, 0.07)",
  "Process & System Security": "rgba(95, 174, 95, 0.07)",
  "Organizational Security": "rgba(241, 169, 131, 0.08)",
};

const DEPT_COLOR: Record<string, string> = {
  "Infrastructure & Cloud Security": "#2c5fc7",
  "AppSec & Product Security": "#7ca5f0",
  "Security Engineering & Data Security": "#3e8c3e",
  "Security Operations (SOC & Incident Response)": "#85c785",
  "GRC & TPRM": "#d68b6c",
  "Business Resilience & Security Awareness": "#f4baa0",
};

const DEPT_SHORT: Record<string, string> = {
  "Infrastructure & Cloud Security": "Infrastructure & Cloud",
  "AppSec & Product Security": "AppSec & Product",
  "Security Engineering & Data Security": "Security Engineering & Data",
  "Security Operations (SOC & Incident Response)": "Security Operations",
  "GRC & TPRM": "GRC & TPRM",
  "Business Resilience & Security Awareness": "Business Resilience",
};

const config = {
  baseUrl,
  catColor: CATEGORY_COLOR,
  catTint: CATEGORY_TINT,
  deptColor: DEPT_COLOR,
  deptShort: DEPT_SHORT,
  deptToCat: DEPARTMENT_TO_CATEGORY,
  mlTypes: ML_TYPES,
  departments: DEPARTMENTS,
  categories: DEPARTMENT_CATEGORIES,
};

const dataJson = JSON.stringify(topicsData).replace(/<\//g, "<\\/");
const configJson = JSON.stringify(config).replace(/<\//g, "<\\/");
---

<section class="map-section" aria-label="AI security landscape">
  <div class="map-container">
    <svg id="landscape-svg" viewBox="0 0 1240 760" preserveAspectRatio="xMidYMid meet"></svg>
  </div>
  <div class="map-legend" role="note">
    <span class="legend-hint">Hover or tap a topic to see its connections:</span>
    <span class="legend-item">
      <svg class="legend-line" viewBox="0 0 30 6" preserveAspectRatio="none" aria-hidden="true">
        <line x1="0" y1="3" x2="30" y2="3" stroke="#7a3fb0" stroke-width="2.2"></line>
      </svg>
      Comes before
    </span>
    <span class="legend-item">
      <svg class="legend-line" viewBox="0 0 30 6" preserveAspectRatio="none" aria-hidden="true">
        <line x1="0" y1="3" x2="30" y2="3" stroke="#c2185b" stroke-width="2.2"></line>
      </svg>
      Comes after
    </span>
    <span class="legend-item">
      <svg class="legend-line" viewBox="0 0 30 6" preserveAspectRatio="none" aria-hidden="true">
        <line x1="0" y1="3" x2="30" y2="3" stroke="#8a93a6" stroke-width="2.2" stroke-dasharray="5 3"></line>
      </svg>
      In parallel
    </span>
  </div>
</section>

<script id="topics-data" type="application/json" is:inline set:html={dataJson}></script>
<script id="map-config" type="application/json" is:inline set:html={configJson}></script>

<script>
  import * as d3 from "d3";

  type Maturity = "established" | "emerging" | "experimental";
  type Relation = "before" | "after" | "parallel";
  interface Connection {
    to: string;
    relation: Relation;
  }
  interface Topic {
    slug: string;
    title: string;
    maturity: Maturity;
    ml_types: string[];
    departments: string[];
    connections: Connection[];
  }
  interface Config {
    baseUrl: string;
    catColor: Record<string, string>;
    catTint: Record<string, string>;
    deptColor: Record<string, string>;
    deptShort: Record<string, string>;
    deptToCat: Record<string, string>;
    mlTypes: string[];
    departments: string[];
    categories: string[];
  }

  const topics: Topic[] = JSON.parse(
    document.getElementById("topics-data")!.textContent!,
  );
  const config: Config = JSON.parse(
    document.getElementById("map-config")!.textContent!,
  );

  const VIEW_W = 1240;
  const VIEW_H = 760;
  const MARGIN = { top: 56, right: 28, bottom: 80, left: 220 };
  const INNER_W = VIEW_W - MARGIN.left - MARGIN.right;
  const INNER_H = VIEW_H - MARGIN.top - MARGIN.bottom;

  const svg = d3.select<SVGSVGElement, unknown>("#landscape-svg");

  // Build a bidirectional adjacency map for the hover overlay.
  // A connection declared as A -> {to: B, relation: after} means:
  //   from A's perspective: B comes after
  //   from B's perspective: A comes before
  // Parallel relations are symmetric.
  type AdjacencyEntry = { before: Set<string>; after: Set<string>; parallel: Set<string> };
  const adjacency = new Map<string, AdjacencyEntry>();
  for (const t of topics) {
    adjacency.set(t.slug, { before: new Set(), after: new Set(), parallel: new Set() });
  }
  for (const t of topics) {
    for (const c of t.connections) {
      if (!adjacency.has(c.to)) continue;
      if (c.relation === "after") {
        adjacency.get(t.slug)!.after.add(c.to);
        adjacency.get(c.to)!.before.add(t.slug);
      } else if (c.relation === "before") {
        adjacency.get(t.slug)!.before.add(c.to);
        adjacency.get(c.to)!.after.add(t.slug);
      } else if (c.relation === "parallel") {
        adjacency.get(t.slug)!.parallel.add(c.to);
        adjacency.get(c.to)!.parallel.add(t.slug);
      }
    }
  }

  // Dedupe: a target slug must appear in at most one of {before, after,
  // parallel} per source. Priority: before > after > parallel. This
  // protects against the case where both topics in a pair declared a
  // connection with conflicting relations (e.g. one says "after", the
  // other says "parallel").
  for (const adj of adjacency.values()) {
    for (const s of [...adj.parallel]) {
      if (adj.before.has(s) || adj.after.has(s)) adj.parallel.delete(s);
    }
    for (const s of [...adj.after]) {
      if (adj.before.has(s)) adj.after.delete(s);
    }
  }

  const isTouchDevice = () =>
    typeof window !== "undefined" &&
    window.matchMedia &&
    window.matchMedia("(pointer: coarse)").matches;

  // Active state for touch devices: first tap shows arrows, second tap on
  // the same topic navigates, tap elsewhere clears.
  let activeSlug: string | null = null;

  function splitTitle(title: string, maxPxPerLine: number): string[] {
    const approxCharW = 6.0;
    const maxChars = Math.max(8, Math.floor(maxPxPerLine / approxCharW));

    if (title.length <= maxChars) return [title];

    // Find last space at or before maxChars
    let splitIdx = -1;
    for (let i = Math.min(maxChars, title.length - 1); i > 0; i--) {
      if (title[i] === " ") {
        splitIdx = i;
        break;
      }
    }
    if (splitIdx === -1) {
      // No space found — hard truncate single line
      return [title.slice(0, Math.max(1, maxChars - 1)) + "…"];
    }

    const line1 = title.slice(0, splitIdx).trim();
    let line2 = title.slice(splitIdx).trim();
    if (line2.length > maxChars) {
      line2 = line2.slice(0, Math.max(1, maxChars - 1)) + "…";
    }
    return [line1, line2];
  }

  function singleLine(title: string, maxPxPerLine: number): string {
    const approxCharW = 6.0;
    const maxChars = Math.max(8, Math.floor(maxPxPerLine / approxCharW));
    if (title.length <= maxChars) return title;
    return title.slice(0, Math.max(1, maxChars - 1)) + "…";
  }

  type Box = {
    x: number;
    y: number;
    w: number;
    h: number;
    color: string;
    topic: Topic;
  };

  function computeBoxes(colW: number, rowH: number): Box[] {
    const xBuckets = config.departments;
    const yBuckets = config.mlTypes;

    interface Raw {
      xMinI: number;
      xMaxI: number;
      yMinI: number;
      yMaxI: number;
      topic: Topic;
    }
    const raws: Raw[] = topics.map((t) => {
      const xIdxs = t.departments
        .map((k) => xBuckets.indexOf(k))
        .filter((i) => i >= 0);
      const yIdxs = t.ml_types
        .map((m) => yBuckets.indexOf(m))
        .filter((i) => i >= 0);
      return {
        xMinI: Math.min(...xIdxs),
        xMaxI: Math.max(...xIdxs),
        yMinI: Math.min(...yIdxs),
        yMaxI: Math.max(...yIdxs),
        topic: t,
      };
    });

    // Per-row interval scheduling: assign each topic a sub-row in its
    // primary ML row (yMaxI). Within a row, sub-row 0 is filled first;
    // topics that don't fit horizontally with anything already placed in
    // sub-row 0 get sub-row 1, and so on. This produces the minimum number
    // of sub-rows for the actual overlaps — e.g. SOAR can sit on the same
    // sub-row as GenAI because their X ranges don't touch, even though both
    // overlap with the wider RAG box that sits below.
    const byRow = new Map<number, Raw[]>();
    for (const r of raws) {
      const arr = byRow.get(r.yMaxI) ?? [];
      arr.push(r);
      byRow.set(r.yMaxI, arr);
    }

    const subRowOf = new Map<Raw, number>();
    const subRowCount = new Map<number, number>();

    for (const [row, items] of byRow) {
      items.sort((a, b) => a.xMinI - b.xMinI || a.xMaxI - b.xMaxI);
      const occupied: Raw[][] = [];
      for (const item of items) {
        let placedSub = -1;
        for (let i = 0; i < occupied.length; i++) {
          const fits = occupied[i].every(
            (other) =>
              item.xMaxI < other.xMinI || other.xMaxI < item.xMinI,
          );
          if (fits) {
            occupied[i].push(item);
            placedSub = i;
            break;
          }
        }
        if (placedSub < 0) {
          occupied.push([item]);
          placedSub = occupied.length - 1;
        }
        subRowOf.set(item, placedSub);
      }
      subRowCount.set(row, occupied.length);
    }

    const boxes: Box[] = [];
    const pad = 10;
    // Each box is half a row tall — leaves visible empty space for future
    // topics and lets multi-row spans straddle the boundary between rows
    // cleanly.
    const HEIGHT_FACTOR = 0.5;

    for (const r of raws) {
      const rowSpan = r.yMaxI - r.yMinI + 1;
      const yTopOfTopCell = INNER_H - (r.yMaxI + 1) * rowH;
      const yBottomOfBottomCell = INNER_H - r.yMinI * rowH;
      const yCenter = (yTopOfTopCell + yBottomOfBottomCell) / 2;

      const totalCellH = rowSpan * rowH;
      const baseH = totalCellH * HEIGHT_FACTOR;
      const subRowIdx = subRowOf.get(r) ?? 0;
      const totalSubRows = subRowCount.get(r.yMaxI) ?? 1;

      // Shrink slot height only when sub-rows would otherwise overflow.
      const slotH =
        totalSubRows === 1
          ? baseH
          : Math.min(baseH, totalCellH / totalSubRows - 4);
      const totalStackH = totalSubRows * slotH;
      const stackTop = yCenter - totalStackH / 2;
      const slotY = stackTop + subRowIdx * slotH;

      boxes.push({
        x: r.xMinI * colW + pad,
        y: slotY + 2,
        w: (r.xMaxI - r.xMinI + 1) * colW - 2 * pad,
        h: slotH - 4,
        color: config.deptColor[r.topic.departments[0]],
        topic: r.topic,
      });
    }
    return boxes;
  }

  function render() {
    svg.selectAll("*").remove();
    const xBuckets = config.departments;
    const yBuckets = config.mlTypes;
    const colW = INNER_W / xBuckets.length;
    const rowH = INNER_H / yBuckets.length;
    const catW = INNER_W / 3;

    const root = svg
      .append("g")
      .attr("transform", `translate(${MARGIN.left},${MARGIN.top})`);

    // Tinted background INSIDE each category outline
    root
      .append("g")
      .selectAll("rect.cat-tint")
      .data(config.categories)
      .join("rect")
      .attr("class", "cat-tint")
      .attr("x", (_, i) => i * catW + 2)
      .attr("y", 0)
      .attr("width", catW - 4)
      .attr("height", INNER_H)
      .attr("rx", 10)
      .attr("fill", (d) => config.catTint[d]);

    // Horizontal grid lines between ML rows
    root
      .append("g")
      .selectAll("line")
      .data(yBuckets.slice(0, -1))
      .join("line")
      .attr("x1", 0)
      .attr("x2", INNER_W)
      .attr("y1", (_, i) => (i + 1) * rowH)
      .attr("y2", (_, i) => (i + 1) * rowH)
      .attr("stroke", "var(--map-grid)")
      .attr("opacity", 0.45)
      .attr("stroke-dasharray", "2,5");

    // Sub-column dividers between the 2 departments inside each category
    root
      .append("g")
      .selectAll("line.subdiv")
      .data(config.categories)
      .join("line")
      .attr("class", "subdiv")
      .attr("x1", (_, i) => i * catW + catW / 2)
      .attr("x2", (_, i) => i * catW + catW / 2)
      .attr("y1", 12)
      .attr("y2", INNER_H - 12)
      .attr("stroke", "var(--map-grid)")
      .attr("stroke-dasharray", "3,4")
      .attr("opacity", 0.55);

    // Category outlines + headers
    const catGroups = root
      .append("g")
      .selectAll("g.cat-group")
      .data(config.categories)
      .join("g")
      .attr("class", "cat-group");

    catGroups
      .append("rect")
      .attr("class", "cat-outline")
      .attr("x", (_, i) => i * catW + 2)
      .attr("y", 0)
      .attr("width", catW - 4)
      .attr("height", INNER_H)
      .attr("rx", 10)
      .attr("fill", "none")
      .attr("stroke", (d) => config.catColor[d])
      .attr("stroke-width", 2)
      .attr("opacity", 0.9);

    catGroups
      .append("text")
      .attr("class", "cat-label")
      .attr("x", (_, i) => i * catW + catW / 2)
      .attr("y", -18)
      .attr("text-anchor", "middle")
      .attr("fill", (d) => config.catColor[d])
      .attr("font-size", 15)
      .attr("font-weight", 700)
      .text((d) => d);

    // Department labels (always shown)
    root
      .append("g")
      .selectAll("text.dept-label")
      .data(config.departments)
      .join("text")
      .attr("class", "dept-label")
      .attr("x", (_, i) => i * colW + colW / 2)
      .attr("y", INNER_H + 22)
      .attr("text-anchor", "middle")
      .attr("fill", "var(--text)")
      .attr("font-size", 11)
      .attr("font-weight", 500)
      .text((d) => config.deptShort[d]);

    // Y axis ML labels (full names)
    root
      .append("g")
      .selectAll("text.ml-label")
      .data(yBuckets)
      .join("text")
      .attr("class", "ml-label")
      .attr("x", -12)
      .attr("y", (_, i) => INNER_H - i * rowH - rowH / 2)
      .attr("text-anchor", "end")
      .attr("dominant-baseline", "central")
      .attr("fill", "var(--text)")
      .attr("font-size", 12)
      .attr("font-weight", 500)
      .text((d) => d);

    // Axis titles
    svg
      .append("text")
      .attr("x", MARGIN.left + INNER_W / 2)
      .attr("y", VIEW_H - 16)
      .attr("text-anchor", "middle")
      .attr("fill", "var(--text-muted)")
      .attr("font-size", 12)
      .attr("font-style", "italic")
      .text("Scope of Business Exposure  →");

    svg
      .append("text")
      .attr(
        "transform",
        `translate(20, ${MARGIN.top + INNER_H / 2}) rotate(-90)`,
      )
      .attr("text-anchor", "middle")
      .attr("fill", "var(--text-muted)")
      .attr("font-size", 12)
      .attr("font-style", "italic")
      .text("Required Data Maturity  →");

    // Topic boxes + arrow overlay
    const boxes = computeBoxes(colW, rowH);
    const boxBySlug = new Map<string, Box>(
      boxes.map((b) => [b.topic.slug, b]),
    );

    // Arrow-head markers in three colours: before (orange), after (green),
    // parallel (grey, dashed line uses the same marker).
    const defs = svg.append("defs");
    function addMarker(id: string, fill: string) {
      defs
        .append("marker")
        .attr("id", id)
        .attr("viewBox", "0 0 10 10")
        .attr("refX", 9)
        .attr("refY", 5)
        .attr("markerWidth", 7)
        .attr("markerHeight", 7)
        .attr("orient", "auto-start-reverse")
        .append("path")
        .attr("d", "M 0 0 L 10 5 L 0 10 z")
        .attr("fill", fill);
    }
    addMarker("arrow-before", "#7a3fb0");
    addMarker("arrow-after", "#c2185b");
    addMarker("arrow-parallel", "#8a93a6");

    // Node layer first so that the arrow layer can be appended on top.
    // Otherwise arrows that pass close to a topic box get hidden behind it.
    const nodeLayer = root.append("g").attr("class", "node-layer");
    const arrowLayer = root
      .append("g")
      .attr("class", "arrow-layer")
      .style("pointer-events", "none");
    const groups = nodeLayer
      .selectAll<SVGGElement, Box>("g")
      .data(boxes)
      .join("g")
      .attr("class", "topic-box")
      .attr("data-slug", (d) => d.topic.slug)
      .attr("transform", (d) => `translate(${d.x},${d.y})`)
      .style("cursor", "pointer")
      .on("click", function (_event, d) {
        if (isTouchDevice()) {
          if (activeSlug === d.topic.slug) {
            window.location.href = `${config.baseUrl}/topics/${d.topic.slug}/`;
          } else {
            activeSlug = d.topic.slug;
            showArrows(d.topic.slug);
          }
        } else {
          window.location.href = `${config.baseUrl}/topics/${d.topic.slug}/`;
        }
      })
      .on("mouseenter", function (_event, d) {
        if (isTouchDevice()) return;
        showArrows(d.topic.slug);
      })
      .on("mouseleave", function () {
        if (isTouchDevice()) return;
        clearArrows();
      });

    // Tap outside the map on touch devices clears the active state.
    if (typeof document !== "undefined") {
      document.addEventListener("click", (event) => {
        if (!isTouchDevice()) return;
        const mapEl = document.querySelector(".map-container");
        if (mapEl && !mapEl.contains(event.target as Node)) {
          activeSlug = null;
          clearArrows();
        }
      });
    }

    // Helper: anchor point on the edge of a box facing the other box.
    function edgeAnchor(box: Box, toX: number, toY: number) {
      const cx = box.x + box.w / 2;
      const cy = box.y + box.h / 2;
      const dx = toX - cx;
      const dy = toY - cy;
      if (Math.abs(dx) < 0.001 && Math.abs(dy) < 0.001) return { x: cx, y: cy };
      const halfW = box.w / 2;
      const halfH = box.h / 2;
      const slopeOut = Math.abs(dy / (dx || 0.0001));
      const slopeBox = halfH / halfW;
      if (slopeOut <= slopeBox) {
        const side = dx > 0 ? 1 : -1;
        return { x: cx + side * halfW, y: cy + side * halfW * (dy / (dx || 0.0001)) };
      }
      const side = dy > 0 ? 1 : -1;
      return { x: cx + side * halfH * (dx / (dy || 0.0001)), y: cy + side * halfH };
    }

    // Returns a stable key that identifies arrows which would be drawn on
    // the same "lane" — same vertical X for Case B, same horizontal Y for
    // Case A. Arrows sharing a lane key get spread out so they do not all
    // stack on the same pixel line.
    function laneKey(src: Box, tgt: Box): string {
      const yOMin = Math.max(src.y, tgt.y);
      const yOMax = Math.min(src.y + src.h, tgt.y + tgt.h);
      const xOMin = Math.max(src.x, tgt.x);
      const xOMax = Math.min(src.x + src.w, tgt.x + tgt.w);
      const yOverlap = yOMin < yOMax;
      const xOverlap = xOMin < xOMax;
      if (yOverlap && !xOverlap) {
        return `h:${Math.round((yOMin + yOMax) / 2)}`;
      }
      if (xOverlap && !yOverlap) {
        return `v:${Math.round((xOMin + xOMax) / 2)}`;
      }
      // Unique key so other cases never get grouped (no offset applied).
      return `u:${src.topic.slug}->${tgt.topic.slug}`;
    }

    // Path strategy for an arrow from src to tgt, based on how the two
    // boxes overlap geometrically. Overlap-based logic is more robust than
    // centre proximity when boxes have different widths (multi-column
    // topics) or sit in different sub-rows of the same ML band.
    //
    // `laneOffset` shifts the rendering line perpendicular to the arrow
    // direction so that multiple arrows on the same lane are visible
    // side-by-side rather than stacking on top of each other.
    function arrowPath(src: Box, tgt: Box, laneOffset = 0): string {
      const sCx = src.x + src.w / 2;
      const sCy = src.y + src.h / 2;
      const tCx = tgt.x + tgt.w / 2;
      const tCy = tgt.y + tgt.h / 2;
      const dx = tCx - sCx;
      const dy = tCy - sCy;

      // Direct box-rect overlap detection (range overlap on each axis).
      const yOverlapMin = Math.max(src.y, tgt.y);
      const yOverlapMax = Math.min(src.y + src.h, tgt.y + tgt.h);
      const yOverlapExists = yOverlapMin < yOverlapMax;
      const xOverlapMin = Math.max(src.x, tgt.x);
      const xOverlapMax = Math.min(src.x + src.w, tgt.x + tgt.w);
      const xOverlapExists = xOverlapMin < xOverlapMax;

      // --- Case A: side-by-side (Y-overlap, no X-overlap) ---
      // Straight horizontal line through the Y-overlap midpoint. The
      // laneOffset shifts the line vertically, clamped to stay inside
      // both boxes' Y range so the anchors remain on the box edges.
      if (yOverlapExists && !xOverlapExists) {
        const overlapHalf = (yOverlapMax - yOverlapMin) / 2;
        const clamped = Math.max(
          -overlapHalf + 4,
          Math.min(overlapHalf - 4, laneOffset),
        );
        const lineY = (yOverlapMin + yOverlapMax) / 2 + clamped;
        const goingRight = dx > 0;
        const sX = goingRight ? src.x + src.w : src.x;
        const tX = goingRight ? tgt.x : tgt.x + tgt.w;
        return `M ${sX} ${lineY} L ${tX} ${lineY}`;
      }

      // --- Case B: vertically stacked (X-overlap, no Y-overlap) ---
      // Straight vertical line through the X-overlap midpoint. The
      // laneOffset shifts the line horizontally, clamped to stay inside
      // both boxes' X range.
      if (xOverlapExists && !yOverlapExists) {
        const overlapHalf = (xOverlapMax - xOverlapMin) / 2;
        const clamped = Math.max(
          -overlapHalf + 4,
          Math.min(overlapHalf - 4, laneOffset),
        );
        const lineX = (xOverlapMin + xOverlapMax) / 2 + clamped;
        const goingDown = dy > 0;
        const sY = goingDown ? src.y + src.h : src.y;
        const tY = goingDown ? tgt.y : tgt.y + tgt.h;
        return `M ${lineX} ${sY} L ${lineX} ${tY}`;
      }

      // --- Case C: both axes overlap (boxes essentially on top of each
      // other, e.g. one very wide multi-column box sitting under a narrow
      // one). Big external arc above or below. ---
      if (xOverlapExists && yOverlapExists) {
        const topMin = Math.min(src.y, tgt.y);
        const botMax = Math.max(src.y + src.h, tgt.y + tgt.h);
        const goUp = topMin >= INNER_H - botMax;
        const arcHeight = 80;
        const sAnchor = { x: sCx, y: goUp ? src.y : src.y + src.h };
        const tAnchor = { x: tCx, y: goUp ? tgt.y : tgt.y + tgt.h };
        const controlY = goUp ? topMin - arcHeight : botMax + arcHeight;
        const controlX = (sCx + tCx) / 2;
        return `M ${sAnchor.x} ${sAnchor.y} Q ${controlX} ${controlY} ${tAnchor.x} ${tAnchor.y}`;
      }

      // --- Case D: no overlap on either axis (diagonal) ---
      // Edge-to-edge gentle Bezier.
      const s = edgeAnchor(src, tCx, tCy);
      const t = edgeAnchor(tgt, sCx, sCy);
      const mx = (s.x + t.x) / 2;
      const my = (s.y + t.y) / 2;
      const ddx = t.x - s.x;
      const ddy = t.y - s.y;
      const dist = Math.sqrt(ddx * ddx + ddy * ddy);
      if (dist < 1) return `M ${s.x} ${s.y} L ${t.x} ${t.y}`;
      const offset = Math.min(40, dist * 0.18);
      const cx = mx + (-ddy / dist) * offset;
      const cy = my + (ddx / dist) * offset;
      return `M ${s.x} ${s.y} Q ${cx} ${cy} ${t.x} ${t.y}`;
    }

    function showArrows(slug: string) {
      const adj = adjacency.get(slug);
      if (!adj) return;
      const focal = boxBySlug.get(slug);
      if (!focal) return;

      // Dim every box, then un-dim focal + connected ones.
      groups.classed("is-dimmed", true).classed("is-focal", false).classed("is-related", false);
      const related = new Set<string>([
        ...adj.before,
        ...adj.after,
        ...adj.parallel,
      ]);
      groups
        .filter((d) => d.topic.slug === slug)
        .classed("is-focal", true)
        .classed("is-dimmed", false)
        .raise();
      groups
        .filter((d) => related.has(d.topic.slug))
        .classed("is-related", true)
        .classed("is-dimmed", false);

      arrowLayer.selectAll("*").remove();

      // Build a list of arrows to render, then group by lane key so that
      // multiple arrows sharing the same lane get spread out symmetrically.
      type Pending = {
        src: Box;
        tgt: Box;
        cls: string;
        marker: string;
      };
      const pending: Pending[] = [];

      adj.before.forEach((otherSlug) => {
        const other = boxBySlug.get(otherSlug);
        if (!other) return;
        pending.push({
          src: other,
          tgt: focal,
          cls: "conn-arrow conn-before",
          marker: "url(#arrow-before)",
        });
      });
      adj.after.forEach((otherSlug) => {
        const other = boxBySlug.get(otherSlug);
        if (!other) return;
        pending.push({
          src: focal,
          tgt: other,
          cls: "conn-arrow conn-after",
          marker: "url(#arrow-after)",
        });
      });
      adj.parallel.forEach((otherSlug) => {
        const other = boxBySlug.get(otherSlug);
        if (!other) return;
        pending.push({
          src: focal,
          tgt: other,
          cls: "conn-arrow conn-parallel",
          marker: "url(#arrow-parallel)",
        });
      });

      // Group by lane key so we can offset overlapping arrows.
      const byLane = new Map<string, Pending[]>();
      pending.forEach((p) => {
        const key = laneKey(p.src, p.tgt);
        const arr = byLane.get(key) ?? [];
        arr.push(p);
        byLane.set(key, arr);
      });

      const LANE_SPACING = 14;
      byLane.forEach((group) => {
        const n = group.length;
        group.forEach((p, i) => {
          const offset = n > 1 ? (i - (n - 1) / 2) * LANE_SPACING : 0;
          arrowLayer
            .append("path")
            .attr("class", p.cls)
            .attr("d", arrowPath(p.src, p.tgt, offset))
            .attr("marker-end", p.marker);
        });
      });
    }

    function clearArrows() {
      activeSlug = null;
      arrowLayer.selectAll("*").remove();
      groups.classed("is-dimmed", false).classed("is-focal", false).classed("is-related", false);
    }

    groups
      .append("rect")
      .attr("width", (d) => d.w)
      .attr("height", (d) => d.h)
      .attr("rx", 5)
      .attr("fill", (d) => d.color)
      .attr("fill-opacity", 0.92)
      .attr("stroke", "var(--map-box-stroke)")
      .attr("stroke-width", 1);

    groups
      .append("text")
      .attr("x", (d) => d.w / 2)
      .attr("y", (d) => d.h / 2)
      .attr("text-anchor", "middle")
      .attr("dominant-baseline", "central")
      .attr("fill", "#0f1115")
      .attr("font-size", 11)
      .attr("font-weight", 600)
      .attr("pointer-events", "none")
      .each(function (d) {
        if (d.h < 14) return;
        const t = d3.select(this);
        const usable = d.w - 10;
        if (d.h < 26) {
          // Not enough vertical room for two lines — single line, possibly truncated.
          t.text(singleLine(d.topic.title, usable));
          return;
        }
        const lines = splitTitle(d.topic.title, usable);
        t.text(null);
        if (lines.length === 1) {
          t.append("tspan")
            .attr("x", d.w / 2)
            .attr("dy", 0)
            .text(lines[0]);
        } else {
          t.append("tspan")
            .attr("x", d.w / 2)
            .attr("dy", "-0.55em")
            .text(lines[0]);
          t.append("tspan")
            .attr("x", d.w / 2)
            .attr("dy", "1.15em")
            .text(lines[1]);
        }
      });
  }

  render();
</script>

<style>
  .map-section {
    --map-grid: var(--border);
    --map-box-stroke: var(--bg);
    margin-top: 1rem;
  }

  .map-container {
    position: relative;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem;
  }

  #landscape-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .topic-box rect {
    transition: filter 0.12s, opacity 0.18s;
  }

  .topic-box:hover rect {
    filter: brightness(1.08);
  }

  /* Connection-overlay states: when one topic is "focal", every other box
     dims, the connected ones stay visible, the focal one gets a thicker
     outline. */
  #landscape-svg :global(.topic-box.is-dimmed rect) {
    opacity: 0.22;
  }

  #landscape-svg :global(.topic-box.is-related rect) {
    opacity: 1;
    stroke-width: 1.5;
  }

  #landscape-svg :global(.topic-box.is-focal rect) {
    stroke: var(--text);
    stroke-width: 2.5;
    filter: brightness(1.05);
  }

  #landscape-svg :global(.conn-arrow) {
    fill: none;
    stroke-width: 1.8;
    opacity: 0.85;
  }

  #landscape-svg :global(.conn-arrow.conn-before) {
    stroke: #7a3fb0;
  }

  #landscape-svg :global(.conn-arrow.conn-after) {
    stroke: #c2185b;
  }

  #landscape-svg :global(.conn-arrow.conn-parallel) {
    stroke: #8a93a6;
    stroke-dasharray: 6 5;
  }

  .map-legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.4rem 1.4rem;
    margin-top: 0.6rem;
    padding: 0.55rem 0.8rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .legend-hint {
    font-style: italic;
    margin-right: 0.4rem;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text);
  }

  .legend-line {
    width: 32px;
    height: 6px;
    display: inline-block;
  }
</style>
