---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import KeyFactorBars from "../../components/KeyFactorBars.astro";
import ConnectionsDiagram, {
  type RelatedTopic,
} from "../../components/ConnectionsDiagram.astro";
import { DEPARTMENT_COLOR } from "../../content/config";

function colorFor(dept?: string): string {
  if (!dept) return "var(--text-muted)";
  return (
    (DEPARTMENT_COLOR as Record<string, string>)[dept] ?? "var(--text-muted)"
  );
}

export async function getStaticPaths() {
  const topics = await getCollection("topics");
  return topics.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const { Content } = await topic.render();
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

// Own outgoing connections.
const ownRelated: RelatedTopic[] = await Promise.all(
  topic.data.connections.map(async (c) => {
    const target = await getEntry(c.to);
    return {
      slug: target.slug,
      title: target.data.title,
      note: c.note,
      position: c.relation as "before" | "after" | "parallel",
      department: target.data.departments[0],
    };
  }),
);

// Incoming — flip the relation so it reads from the current topic's view.
const flip = (r: "before" | "after" | "parallel") =>
  r === "before" ? "after" : r === "after" ? "before" : "parallel";

const all = await getCollection("topics");
const incomingRelated: RelatedTopic[] = all
  .filter((t) => t.slug !== topic.slug)
  .flatMap((t) =>
    t.data.connections
      .filter((c) => c.to.slug === topic.slug)
      .map((c) => ({
        slug: t.slug,
        title: t.data.title,
        note: c.note,
        position: flip(c.relation as "before" | "after" | "parallel") as
          | "before"
          | "after"
          | "parallel",
        department: t.data.departments[0],
      })),
  );

// Merge + dedupe by slug. Own declaration wins.
const seen = new Set<string>();
const related: RelatedTopic[] = [];
for (const r of [...ownRelated, ...incomingRelated]) {
  if (seen.has(r.slug)) continue;
  seen.add(r.slug);
  related.push(r);
}

const beforeTopics = related.filter((r) => r.position === "before");
const afterTopics = related.filter((r) => r.position === "after");
const parallelTopics = related.filter((r) => r.position === "parallel");

const repoEditUrl = `https://github.com/Part-IO/ai-security-landscape/edit/main/src/content/topics/${topic.slug}.md`;
---

<Base title={topic.data.title}>
  <p class="back-link">
    <a href={baseUrl || "/"}>← Back to landscape</a>
  </p>

  <div class="topic-layout">
    <aside class="topic-sidebar">
      <h2 class="sidebar-heading">Key Factors</h2>
      <KeyFactorBars
        factors={topic.data.factors}
        notes={topic.data.factor_notes}
      />
    </aside>

    <article class="topic-main">
      <header class="topic-hero">
        <h1>{topic.data.title}</h1>
        <p class="topic-hero-meta">
          <span class={`badge badge-${topic.data.maturity}`}>{topic.data.maturity}</span>
          <span class="meta-sep">·</span>
          <span>{topic.data.ml_types.join(" · ")}</span>
          <span class="meta-sep">·</span>
          <span>{topic.data.departments.join(" · ")}</span>
        </p>
      </header>

      {
        topic.data.hero_image && (
          <figure class="hero-image">
            <Image
              src={topic.data.hero_image.src}
              alt={topic.data.hero_image.alt}
              loading="eager"
            />
            {topic.data.hero_image.caption && (
              <figcaption>{topic.data.hero_image.caption}</figcaption>
            )}
          </figure>
        )
      }

      <div class="prose">
        <Content />
      </div>

      <section class="section">
        <h2>Related topics</h2>
        <ConnectionsDiagram
          currentTitle={topic.data.title}
          currentDepartment={topic.data.departments[0]}
          related={related}
        />

        {
          beforeTopics.length > 0 && (
            <div class="related-block before-block">
              <h3>Where to start?</h3>
              <p class="block-hint">
                Topics typically tackled <em>before</em> this one. Their output
                becomes input you can build on.
              </p>
              <ul class="related-list">
                {beforeTopics.map((c) => (
                  <li
                    class="related-item"
                    style={`--dept-color: ${colorFor(c.department)}`}
                  >
                    <a
                      href={`${baseUrl}/topics/${c.slug}/`}
                      class="related-title"
                    >
                      {c.title}
                    </a>
                    {c.note && <p class="related-note">{c.note}</p>}
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        {
          afterTopics.length > 0 && (
            <div class="related-block after-block">
              <h3>After finishing</h3>
              <p class="block-hint">
                Topics that build on the output of this one. Pick the next
                step in the pipeline.
              </p>
              <ul class="related-list">
                {afterTopics.map((c) => (
                  <li
                    class="related-item"
                    style={`--dept-color: ${colorFor(c.department)}`}
                  >
                    <a
                      href={`${baseUrl}/topics/${c.slug}/`}
                      class="related-title"
                    >
                      {c.title}
                    </a>
                    {c.note && <p class="related-note">{c.note}</p>}
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        {
          parallelTopics.length > 0 && (
            <div class="related-block parallel-block">
              <h3>In parallel</h3>
              <p class="block-hint">
                Topics that share the same data or pipeline with this one.
                Often worked on in parallel rather than sequentially.
              </p>
              <ul class="related-list">
                {parallelTopics.map((c) => (
                  <li
                    class="related-item"
                    style={`--dept-color: ${colorFor(c.department)}`}
                  >
                    <a
                      href={`${baseUrl}/topics/${c.slug}/`}
                      class="related-title"
                    >
                      {c.title}
                    </a>
                    {c.note && <p class="related-note">{c.note}</p>}
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </section>

      {
        topic.data.references.length > 0 && (
          <section class="section">
            <h2>Examples & References</h2>
            <ul class="references">
              {topic.data.references.map((ref) => {
                const u = new URL(ref.url);
                const host = u.host.replace(/^www\./, "");
                const path = u.pathname.replace(/^\//, "").replace(/\/$/, "");
                const label = path
                  ? `${host} · ${path}`
                  : host;
                return (
                  <li class="reference-item">
                    <a
                      href={ref.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="reference-link"
                    >
                      {label}
                      <span class="reference-host">{u.host}</span>
                    </a>
                    {ref.description && (
                      <p class="reference-desc">{ref.description}</p>
                    )}
                  </li>
                );
              })}
            </ul>
          </section>
        )
      }

      <p class="edit-link">
        Spotted an error or want to extend this topic?{" "}
        <a href={repoEditUrl} target="_blank" rel="noopener noreferrer">
          Edit on GitHub
        </a>
        .
      </p>
    </article>
  </div>
</Base>

<style>
  .back-link {
    margin: 0 0 1rem;
    font-size: 0.9rem;
  }

  .topic-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 860px) {
    .topic-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .topic-sidebar {
    position: sticky;
    top: 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.1rem 1.1rem 1.25rem;
  }

  @media (max-width: 860px) {
    .topic-sidebar {
      position: static;
      order: 2;
    }
  }

  .sidebar-heading {
    margin: 0 0 0.1rem;
    font-size: 1.05rem;
  }

  .topic-main {
    min-width: 0;
  }

  .topic-hero {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }

  .topic-hero h1 {
    margin: 0 0 0.5rem;
    font-size: 2rem;
    line-height: 1.2;
  }

  .topic-hero-meta {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .meta-sep {
    color: var(--border);
  }

  .hero-image {
    margin: 0 0 1.75rem;
    padding: 0.75rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
  }

  .hero-image :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .hero-image figcaption {
    margin-top: 0.6rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-style: italic;
  }

  .topic-main .prose {
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .topic-main .prose > :first-child {
    margin-top: 0;
  }

  .topic-main .prose h2 {
    margin-top: 2rem;
    font-size: 1.3rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--border);
  }

  .topic-main .prose h3 {
    margin-top: 1.5rem;
  }

  .topic-main .prose ul,
  .topic-main .prose ol {
    padding-left: 1.5rem;
  }

  .section {
    margin-top: 2.5rem;
  }

  .section > h2 {
    margin-bottom: 0.6rem;
    font-size: 1.3rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--border);
  }

  .section-hint {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: 0.4rem;
    margin-bottom: 1rem;
  }

  .related-block {
    margin-top: 1.5rem;
    padding: 1rem 1.1rem 1.1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
    border-left-width: 3px;
  }

  .before-block {
    border-left-color: #f1a983;
  }

  .after-block {
    border-left-color: #85c785;
  }

  .parallel-block {
    border-left-color: #8a93a6;
  }

  .related-block h3 {
    margin: 0 0 0.2rem;
    font-size: 1.02rem;
  }

  .block-hint {
    margin: 0 0 0.8rem;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }

  .related-item {
    padding: 0.65rem 0.85rem 0.7rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 4px solid var(--dept-color, var(--text-muted));
    border-radius: 6px;
    line-height: 1.5;
  }

  .related-title {
    display: block;
    font-weight: 600;
    font-size: 0.98rem;
    line-height: 1.35;
  }

  .related-note {
    margin: 0.35rem 0 0;
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .references {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .reference-item {
    padding: 0.8rem 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .reference-link {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    font-weight: 600;
    word-break: break-word;
  }

  .reference-host {
    font-weight: 400;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .reference-desc {
    margin: 0.45rem 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .edit-link {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>
