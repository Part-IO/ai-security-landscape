---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AI Security Landscape",
  description = "Open landscape of AI use cases in cybersecurity, mapped by ML approach and security department.",
} = Astro.props;

const fullTitle =
  title === "AI Security Landscape" ? title : `${title} · AI Security Landscape`;
const baseHref = import.meta.env.BASE_URL;

// Optional brand logo, controlled by env vars at build time. A downstream
// fork (e.g. secureIO's whitelabel version) places asset files under
// public/ and points env vars at them; the logo renders in the header.
// Default: no logo, header looks unchanged.
//
// Two variants are supported so the logo can adapt to the site's light /
// dark theme:
//   BRAND_LOGO_LIGHT  path to the logo file for light mode
//   BRAND_LOGO_DARK   path to the logo file for dark mode
// BRAND_LOGO_PATH is the legacy single-logo fallback used for both modes.
//
// Pre-pend the configured Astro base path to relative asset paths so the
// logo resolves correctly on GitHub Pages project sites
// (https://<org>.github.io/<repo>/...). Absolute URLs (http/https) are
// passed through unchanged so a logo hosted elsewhere also works.
function withBase(p: string): string {
  if (!p) return "";
  if (/^https?:\/\//i.test(p)) return p;
  const base = baseHref.replace(/\/$/, "");
  const path = p.startsWith("/") ? p : "/" + p;
  return `${base}${path}`;
}

const brandLogoEnv = process.env.BRAND_LOGO_PATH || "";
const brandLogoLightRaw =
  process.env.BRAND_LOGO_LIGHT || brandLogoEnv || process.env.BRAND_LOGO_DARK || "";
const brandLogoDarkRaw =
  process.env.BRAND_LOGO_DARK || brandLogoEnv || process.env.BRAND_LOGO_LIGHT || "";
const brandLogoLight = withBase(brandLogoLightRaw);
const brandLogoDark = withBase(brandLogoDarkRaw);
const brandLogoHref = process.env.BRAND_LOGO_HREF || baseHref;
const brandLogoAlt = process.env.BRAND_LOGO_ALT || "Brand logo";
const hasBrandLogo = brandLogoLight !== "" || brandLogoDark !== "";

// Optional footer additions, configured per deployment via env vars.
//   FOOTER_PROJECT_BY_TEXT  display text of the "A project by X" line
//   FOOTER_PROJECT_BY_URL   URL the text links to
//   FOOTER_IMPRESSUM_URL    URL for the "Impressum" link (German legal notice)
// All three default to empty; in that case the footer renders only the
// default "Open source · MIT License · Contributions welcome" line.
const footerProjectByText = process.env.FOOTER_PROJECT_BY_TEXT || "";
const footerProjectByUrl = process.env.FOOTER_PROJECT_BY_URL || "";
const footerImpressumUrl = process.env.FOOTER_IMPRESSUM_URL || "";
const hasProjectBy =
  footerProjectByText !== "" && footerProjectByUrl !== "";
const hasImpressum = footerImpressumUrl !== "";
const hasFooterByline = hasProjectBy || hasImpressum;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem("theme");
          const sys = window.matchMedia("(prefers-color-scheme: light)").matches
            ? "light"
            : "dark";
          const theme = saved || sys;
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          /* localStorage might be disabled */
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <div class="site-title">
          <a href={baseHref}>AI Security Landscape</a>
        </div>
        <div class="site-header-right">
          <div class="site-tagline">AI use cases in cybersecurity, mapped.</div>
          {
            hasBrandLogo && (
              <a
                href={brandLogoHref}
                class="brand-logo-link"
                target={brandLogoHref.startsWith("http") ? "_blank" : undefined}
                rel={brandLogoHref.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                {brandLogoLight && (
                  <img
                    src={brandLogoLight}
                    alt={brandLogoAlt}
                    class="brand-logo brand-logo-for-light"
                  />
                )}
                {brandLogoDark && (
                  <img
                    src={brandLogoDark}
                    alt={brandLogoAlt}
                    class="brand-logo brand-logo-for-dark"
                  />
                )}
              </a>
            )
          }
          <button
            type="button"
            class="theme-toggle"
            id="theme-toggle"
            aria-label="Toggle light / dark theme"
            title="Toggle light / dark theme"
          >
            <span class="icon-dark">☀</span>
            <span class="icon-light">☾</span>
          </button>
        </div>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div>Open source · MIT License · Contributions welcome</div>
      {
        hasFooterByline && (
          <div class="footer-byline">
            {hasProjectBy && (
              <span>
                A project by{" "}
                <a
                  href={footerProjectByUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {footerProjectByText}
                </a>
              </span>
            )}
            {hasProjectBy && hasImpressum && (
              <span class="footer-sep"> · </span>
            )}
            {hasImpressum && (
              <a
                href={footerImpressumUrl}
                target={footerImpressumUrl.startsWith("http") ? "_blank" : undefined}
                rel={footerImpressumUrl.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                Impressum
              </a>
            )}
          </div>
        )
      }
    </footer>

    <script>
      const btn = document.getElementById("theme-toggle");
      if (btn) {
        btn.addEventListener("click", () => {
          const current = document.documentElement.getAttribute("data-theme");
          const next = current === "light" ? "dark" : "light";
          document.documentElement.setAttribute("data-theme", next);
          try {
            localStorage.setItem("theme", next);
          } catch (e) {
            /* localStorage disabled */
          }
        });
      }
    </script>
  </body>
</html>
