---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AI Security Landscape",
  description = "Open landscape of AI use cases in cybersecurity, mapped by ML approach and security department.",
} = Astro.props;

const fullTitle =
  title === "AI Security Landscape" ? title : `${title} · AI Security Landscape`;
const baseHref = import.meta.env.BASE_URL;

// Optional brand logo, controlled by env vars at build time. A downstream
// fork (e.g. secureIO's whitelabel version) places asset files under
// public/ and points env vars at them; the logo renders in the header.
// Default: no logo, header looks unchanged.
//
// Two variants are supported so the logo can adapt to the site's light /
// dark theme:
//   BRAND_LOGO_LIGHT  path to the logo file for light mode
//   BRAND_LOGO_DARK   path to the logo file for dark mode
// BRAND_LOGO_PATH is the legacy single-logo fallback used for both modes.
const brandLogoEnv = process.env.BRAND_LOGO_PATH || "";
const brandLogoLight =
  process.env.BRAND_LOGO_LIGHT || brandLogoEnv || process.env.BRAND_LOGO_DARK || "";
const brandLogoDark =
  process.env.BRAND_LOGO_DARK || brandLogoEnv || process.env.BRAND_LOGO_LIGHT || "";
const brandLogoHref = process.env.BRAND_LOGO_HREF || baseHref;
const brandLogoAlt = process.env.BRAND_LOGO_ALT || "Brand logo";
const hasBrandLogo = brandLogoLight !== "" || brandLogoDark !== "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem("theme");
          const sys = window.matchMedia("(prefers-color-scheme: light)").matches
            ? "light"
            : "dark";
          const theme = saved || sys;
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          /* localStorage might be disabled */
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <div class="site-title">
          <a href={baseHref}>AI Security Landscape</a>
        </div>
        <div class="site-header-right">
          <div class="site-tagline">AI use cases in cybersecurity, mapped.</div>
          {
            hasBrandLogo && (
              <a
                href={brandLogoHref}
                class="brand-logo-link"
                target={brandLogoHref.startsWith("http") ? "_blank" : undefined}
                rel={brandLogoHref.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                {brandLogoLight && (
                  <img
                    src={brandLogoLight}
                    alt={brandLogoAlt}
                    class="brand-logo brand-logo-for-light"
                  />
                )}
                {brandLogoDark && (
                  <img
                    src={brandLogoDark}
                    alt={brandLogoAlt}
                    class="brand-logo brand-logo-for-dark"
                  />
                )}
              </a>
            )
          }
          <button
            type="button"
            class="theme-toggle"
            id="theme-toggle"
            aria-label="Toggle light / dark theme"
            title="Toggle light / dark theme"
          >
            <span class="icon-dark">☀</span>
            <span class="icon-light">☾</span>
          </button>
        </div>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      Open source · MIT · Contributions welcome
    </footer>

    <script>
      const btn = document.getElementById("theme-toggle");
      if (btn) {
        btn.addEventListener("click", () => {
          const current = document.documentElement.getAttribute("data-theme");
          const next = current === "light" ? "dark" : "light";
          document.documentElement.setAttribute("data-theme", next);
          try {
            localStorage.setItem("theme", next);
          } catch (e) {
            /* localStorage disabled */
          }
        });
      }
    </script>
  </body>
</html>
